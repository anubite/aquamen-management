{
  "name": "aquamen-management",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm install && (cd backend && npm install) && npm run build:frontend",
    "start": "cd backend && npm start",
    "build:frontend": "cd frontend && npm install && npm run build",
    "install-all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "users": "cd backend && npm run users --",
    "members": "cd backend && npm run members --",
    "test:unit": "cd backend && ./node_modules/.bin/jest tests/*.test.js",
    "test:seed": "cd backend && node scripts/seed-test-data.js",
    "test:reset": "cd backend && node scripts/reset-test-data.js",
    "test:integration": "cd backend && ./node_modules/.bin/jest tests/integration/overview.test.js --runInBand"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}